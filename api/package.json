{
  "name": "swiftpool-api",
  "version": "14.1.0",
  "private": true,
  "description": "SwiftPool API and React frontend single-origin Railway deployment",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all",
    "test": "cross-env NODE_ENV=test DB_NAME=swiftpool_test DB_USER=root SESSION_SECRET=01234567890123456789012345678901 node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "mysql2": "^3.14.2",
    "sequelize": "^6.37.7",
    "uuid": "^11.1.0",
    "sequelize-cli": "^6.6.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^30.0.4",
    "supertest": "^7.1.4"
  }
}
